# ---- Sources (direct TXT URLs with vless:// links) ----
# Comma-separated or JSON array
SOURCES=https://example.com/free_configs.txt

# ---- Backend ----
# json — save to data/alive.json
# marzban — create VLESS users in Marzban
# xray — generate Xray outbound config
# all — all at once
BACKEND=json

# ---- Probing ----
PROBE_TIMEOUT=5
PROBE_CONCURRENCY=20
PROBE_SAMPLE=300

# ---- Marzban (only for BACKEND=marzban) ----
MARZBAN_URL=http://localhost:8000
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=admin
INBOUND_REMARK_PREFIX=[VLS-MGR]

# ---- Monitoring ----
INTERVAL=3600

# ---- Logging ----
LOG_LEVEL=INFO
